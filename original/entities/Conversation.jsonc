{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "coach_client",
        "client_match"
      ],
      "default": "coach_client"
    },
    "participant_emails": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "participant_names": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "coach_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "match_request_id": {
      "type": "string"
    },
    "last_message": {
      "type": "string"
    },
    "last_message_at": {
      "type": "string"
    },
    "is_archived": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "participant_emails"
  ]
}