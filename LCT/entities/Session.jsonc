{
  "name": "Session",
  "type": "object",
  "properties": {
    "coach_id": {
      "type": "string",
      "description": "Reference to Coach entity"
    },
    "client_email": {
      "type": "string"
    },
    "client_name": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "start_time": {
      "type": "string",
      "description": "HH:MM format"
    },
    "duration_minutes": {
      "type": "number",
      "description": "Duration in minutes"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "confirmed",
        "cancelled",
        "completed"
      ],
      "default": "pending"
    },
    "total_price": {
      "type": "number"
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "unpaid",
        "paid"
      ],
      "default": "unpaid"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "electronic",
        "cash",
        "credits"
      ],
      "description": "How the client paid for this session"
    },
    "county": {
      "type": "string",
      "enum": [
        "Oakland",
        "Macomb",
        "Wayne"
      ]
    },
    "notes": {
      "type": "string"
    },
    "session_goals": {
      "type": "string"
    },
    "cancellation_reason": {
      "type": "string"
    },
    "training_plan": {
      "type": "string",
      "description": "Coach-private structured training plan for this client (mirrored on the most recent session)"
    },
    "strengths": {
      "type": "string",
      "description": "Coach-private strengths summary (mirrored on the most recent session)"
    },
    "weaknesses": {
      "type": "string",
      "description": "Coach-private weaknesses / areas to develop (mirrored on the most recent session)"
    },
    "next_session_focus": {
      "type": "string",
      "description": "Coach-private focus for the upcoming session"
    },
    "homework": {
      "type": "string",
      "description": "Homework / between-session work — explicitly shared with the client on their dashboard"
    },
    "client_visible_notes": {
      "type": "string",
      "description": "Shared coach note for this client — explicitly visible on the client dashboard. Distinct from private `notes`."
    }
  },
  "required": [
    "coach_id",
    "client_email",
    "client_name",
    "date",
    "start_time",
    "duration_minutes"
  ]
}